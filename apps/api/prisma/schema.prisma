// NexTradePro (NXP) — Prisma schema
// Postgres (Neon). RBAC with granular admin roles is the core of this schema.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Authentication & Users
// ---------------------------------------------------------------------------

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum KycStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum TradingStatus {
  ACTIVE
  SUSPENDED
}

enum TradingPermission {
  FULL
  READ_ONLY
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String
  fullName      String
  avatarUrl     String?
  status          UserStatus @default(ACTIVE)
  kycStatus       KycStatus  @default(NONE)
  poaStatus       KycStatus  @default(NONE) // proof-of-address verification stage
  twoFactor       Boolean    @default(false)
  twoFactorSecret String?
  referralCode    String?    @unique
  referredById    String?
  brokerId        String?
  demoMode      Boolean    @default(true)
  // Per-user Live Trading access control (admin-managed).
  liveTradingEnabled Boolean           @default(false)
  tradingStatus      TradingStatus     @default(ACTIVE)
  tradingPermission  TradingPermission @default(FULL)
  // Bumped to invalidate all outstanding access/refresh tokens (password reset,
  // password change, email change).
  tokenVersion  Int        @default(0)
  // Password reset (forgot-password) — single-use, time-limited token hash.
  resetTokenHash String?
  resetTokenExp  DateTime?
  // Google (OAuth / OpenID Connect) linkage.
  googleId       String?   @unique
  googleLinkedAt DateTime?
  // Whether the user has a usable email+password login (false for accounts
  // provisioned purely via Google). Guards Google unlink.
  hasPassword    Boolean   @default(true)
  // Email verification (soft — the account is usable but shows a prompt).
  emailVerified       Boolean   @default(false)
  emailVerifyTokenHash String?
  emailVerifyExp      DateTime?
  // Brute-force protection: failed-attempt counter + temporary lock.
  failedLoginCount    Int       @default(0)
  lockedUntil         DateTime?
  lastLoginAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  roles         UserRole[]
  wallets       Wallet[]
  orders        Order[]
  transactions  Transaction[]
  apiKeys       ApiKey[]
  kycSubmissions KycSubmission[]
  notifications Notification[]
  watchlist     WatchlistItem[]
  watchlists    Watchlist[]
  priceAlerts   PriceAlert[]
  addressProofs AddressProof[]
  bankAccounts  BankAccount[]
  payoutWallets PayoutWallet[]
  statOverrides StatOverride[]
  loginEvents   LoginEvent[]
  referrals     User[]          @relation("Referrals")
  referredBy    User?           @relation("Referrals", fields: [referredById], references: [id])
  clients       User[]          @relation("BrokerClients")
  broker        User?           @relation("BrokerClients", fields: [brokerId], references: [id])
  auditLogs     AuditLog[]      @relation("ActorLogs")
  assignedRoles UserRole[]      @relation("AssignedBy")

  @@index([email])
  @@index([status])
}

// ---------------------------------------------------------------------------
// RBAC: Roles + Permissions (many-to-many) + per-user role assignment
// Admin "types" (Withdrawal-Approval Admin, General Admin, KYC Admin, ...) are
// modelled as roles that bundle a set of permissions. A Super Admin assigns
// these roles to any registered user.
// ---------------------------------------------------------------------------

model Role {
  id          String           @id @default(cuid())
  key         String           @unique // e.g. SUPER_ADMIN, WITHDRAWAL_ADMIN
  name        String                   // "Withdrawal Approval Admin"
  description String?
  isSystem    Boolean          @default(false) // system roles cannot be deleted
  isAdmin     Boolean          @default(false) // grants access to the admin panel
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  users       UserRole[]
  permissions RolePermission[]

  @@index([key])
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique // e.g. withdrawals.approve, users.manage
  name        String
  group       String                   // "Withdrawals", "Users", "KYC", ...
  description String?
  createdAt   DateTime         @default(now())

  roles       RolePermission[]

  @@index([group])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model UserRole {
  id           String   @id @default(cuid())
  userId       String
  roleId       String
  assignedById String?
  assignedAt   DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedBy   User?    @relation("AssignedBy", fields: [assignedById], references: [id])

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

// ---------------------------------------------------------------------------
// Trading domain (demo / simulated execution on live prices)
// Every user has fully separate DEMO and LIVE data — wallets, orders and
// transactions are all scoped by `mode`.
// ---------------------------------------------------------------------------

enum AccountMode {
  DEMO
  LIVE
}

model Wallet {
  id        String      @id @default(cuid())
  userId    String
  asset     String      // BTC, ETH, USDT ...
  mode      AccountMode @default(DEMO)
  balance   Decimal     @default(0) @db.Decimal(24, 8)
  locked    Decimal     @default(0) @db.Decimal(24, 8)
  frozen    Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, asset, mode])
  @@index([userId, mode])
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
  STOP // stop-market
  STOP_LIMIT
  TRAILING_STOP
}

enum OrderStatus {
  OPEN // resting working order (limit/stop) awaiting trigger
  FILLED // filled → an open position
  CLOSED
  CANCELLED
  REJECTED
}

// How an open position was closed (for history / analytics).
enum CloseReason {
  MANUAL
  STOP_LOSS
  TAKE_PROFIT
  LIQUIDATION
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  mode      AccountMode @default(DEMO)
  symbol    String      // BTCUSDT
  side      OrderSide
  type      OrderType
  leverage   Int        @default(1)
  price      Decimal    @db.Decimal(24, 8) // entry price for filled positions
  amount     Decimal    @db.Decimal(24, 8) // position size in base asset
  margin     Decimal    @default(0) @db.Decimal(24, 8) // USDT margin reserved while open
  stopLoss   Decimal?   @db.Decimal(24, 8)
  takeProfit Decimal?   @db.Decimal(24, 8)
  // Working-order trigger fields (limit/stop/stop-limit/trailing).
  triggerPrice    Decimal? @db.Decimal(24, 8) // stop trigger / stop-limit activation
  trailingPercent Decimal? @db.Decimal(10, 4) // trailing stop distance (%)
  trailRef        Decimal? @db.Decimal(24, 8) // best price tracked for the trail
  ocoGroupId      String? // links two OCO orders; filling one cancels the other
  filled     Decimal    @default(0) @db.Decimal(24, 8)
  status    OrderStatus @default(OPEN)
  // Position lifecycle — set when a filled position is closed.
  closePrice  Decimal?     @db.Decimal(24, 8)
  realizedPnl Decimal?     @db.Decimal(24, 8)
  closeReason CloseReason?
  closedAt    DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, mode])
  @@index([symbol])
  @@index([status])
}

enum TxType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
}

enum TxStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
}

model Transaction {
  id          String      @id @default(cuid())
  userId      String
  mode        AccountMode @default(DEMO)
  type        TxType
  asset       String
  network     String?
  address     String?
  amount      Decimal     @db.Decimal(24, 8)
  fee         Decimal     @default(0) @db.Decimal(24, 8)
  status      TxStatus    @default(PENDING)
  reference   String?
  note        String? // internal admin note
  reviewedById String?
  reviewedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, mode])
  @@index([status])
  @@index([type])
}

// Admin-managed deposit wallet addresses per asset/network (demo).
model WalletAddress {
  id           String   @id @default(cuid())
  asset        String
  network      String
  address      String
  minDeposit   String   @default("0")
  confirmations Int     @default(2)
  instructions String?
  isDefault    Boolean  @default(false)
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([asset, network])
  @@index([asset])
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  TRADE
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  body      String
  type      NotificationType @default(INFO)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String?
  enabled     Boolean  @default(false)
  updatedAt   DateTime @updatedAt
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// A named, private watchlist (Favorites, Meme Coins, AI, ...). Each list is
// unique to the authenticated user.
model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  name      String
  emoji     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WatchlistItem[]

  @@index([userId])
}

// A symbol inside a watchlist. `watchlistId` is nullable during migration; a
// backfill assigns every legacy item to the user's default list.
model WatchlistItem {
  id          String   @id @default(cuid())
  userId      String
  watchlistId String?
  symbol      String
  createdAt   DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  watchlist Watchlist? @relation(fields: [watchlistId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, symbol])
  @@index([userId])
  @@index([watchlistId])
}

enum AlertCondition {
  ABOVE
  BELOW
  PCT_CHANGE
}

// A price alert evaluated by the background engine against live prices.
model PriceAlert {
  id          String         @id @default(cuid())
  userId      String
  symbol      String
  condition   AlertCondition
  value       Decimal        @db.Decimal(24, 8) // target price, or % for PCT_CHANGE
  refPrice    Decimal?       @db.Decimal(24, 8) // baseline for PCT_CHANGE
  active      Boolean        @default(true)
  triggeredAt DateTime?
  createdAt   DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([active])
}

// Proof-of-Address (POA) — second KYC stage, required for high-value deposits.
model AddressProof {
  id           String    @id @default(cuid())
  userId       String
  docType      String // UTILITY_BILL, BANK_STATEMENT, GOVERNMENT_LETTER, TAX_DOCUMENT
  issuedDate   String? // user-declared issue date (must be within 3 months)
  documentName String?
  documentType String?
  documentData String?   @db.Text
  status       KycStatus @default(PENDING)
  note         String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model KycSubmission {
  id           String    @id @default(cuid())
  userId       String
  fullName     String
  country      String
  idType       String // PASSPORT, NATIONAL_ID, DRIVERS_LICENSE
  idNumber     String? // deprecated — replaced by residential address
  addressLine1 String?
  addressLine2 String?
  dob          String
  documentName String?
  documentType String? // image/png, image/jpeg, application/pdf ...
  documentData String? @db.Text // base64 data URL of the uploaded ID
  status       KycStatus @default(PENDING)
  createdAt    DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  label     String
  prefix    String // shown to the user, e.g. nxp_live_AbC1
  lastFour  String
  revoked   Boolean   @default(false)
  createdAt DateTime  @default(now())
  lastUsed  DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Withdrawal destinations — saved per user, private, one default each.
// ---------------------------------------------------------------------------

model BankAccount {
  id                String   @id @default(cuid())
  userId            String
  accountHolderName String
  bankName          String
  accountNumber     String
  iban              String?
  swiftBic          String?
  branchName        String?
  branchAddress     String?
  country           String
  currency          String   @default("USD")
  isDefault         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PayoutWallet {
  id        String   @id @default(cuid())
  userId    String
  label     String
  asset     String // BTC, ETH, USDT, USDC, BNB, SOL, XRP, DOGE, ADA, LTC
  network   String
  address   String
  memoTag   String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Admin Profit & Loss Manager — per-user, per-mode stat overrides. Any non-null
// field overrides the value computed from real trades (used for presentations /
// account tuning). All changes are audited.
// ---------------------------------------------------------------------------

model StatOverride {
  id            String      @id @default(cuid())
  userId        String
  mode          AccountMode @default(DEMO)
  realizedPnl   Float?
  unrealizedPnl Float?
  dailyPnl      Float?
  weeklyPnl     Float?
  monthlyPnl    Float?
  lifetimePnl   Float?
  roi           Float?
  tradingVolume Float?
  winRate       Float?
  lossRate      Float?
  updatedById   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mode])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Market Data Service — the Coin universe (150+ assets). Coins are seeded and
// kept fresh by the background sync job; they are NEVER hardcoded in the app.
// The frontend only ever reads coin data through the backend.
// ---------------------------------------------------------------------------

model Coin {
  id             String   @id @default(cuid())
  symbol         String   @unique // BTC, ETH, SOL ...
  pair           String? // trading pair on the exchange, e.g. BTCUSDT
  name           String
  logoUrl        String?
  // Latest market snapshot (refreshed by the sync job).
  price          Float    @default(0)
  change24h      Float    @default(0) // percent
  change7d       Float    @default(0) // percent
  high24h        Float    @default(0)
  low24h         Float    @default(0)
  marketCap      Float    @default(0)
  volume24h      Float    @default(0)
  rank           Int?
  circulating    Float?
  maxSupply      Float?
  // Static metadata.
  website        String?
  explorer       String?
  whitepaper     String?
  // Comma-separated category keys (see MarketCategory). Kept denormalized for
  // fast filtering; also queryable via the `categories` relation.
  categoryKeys   String   @default("")
  // Admin/trading controls.
  tradingEnabled Boolean  @default(true)
  demoEnabled    Boolean  @default(true)
  visible        Boolean  @default(true)
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  categories     CoinCategory[]

  @@index([rank])
  @@index([marketCap])
  @@index([visible])
}

model CoinCategory {
  id       String @id @default(cuid())
  coinId   String
  category String // LAYER1, LAYER2, DEFI, MEME, AI, GAMING, METAVERSE, STABLECOIN, INFRA, EXCHANGE, PRIVACY, RWA
  coin     Coin   @relation(fields: [coinId], references: [id], onDelete: Cascade)

  @@unique([coinId, category])
  @@index([category])
}

// ---------------------------------------------------------------------------
// Announcements / news — managed by Content Admins, shown on the public site
// ---------------------------------------------------------------------------

enum AnnouncementCategory {
  UPDATE
  MARKET
  SECURITY
  PROMOTION
}

model Announcement {
  id         String               @id @default(cuid())
  title      String
  body       String
  category   AnnouncementCategory  @default(UPDATE)
  published  Boolean               @default(true)
  authorId   String?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@index([published])
  @@index([category])
}

// ---------------------------------------------------------------------------
// Login events — powers recent-activity history, new-device detection, and
// brute-force lockout. One row per sign-in attempt (success or failure).
// ---------------------------------------------------------------------------

model LoginEvent {
  id        String   @id @default(cuid())
  userId    String
  ip        String?
  userAgent String?
  device    String? // human summary, e.g. "Chrome on macOS"
  success   Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ---------------------------------------------------------------------------
// Audit logging — every admin action is recorded
// ---------------------------------------------------------------------------

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String   // role.assign, withdrawal.approve, user.suspend ...
  target    String?  // affected entity id
  meta      Json?
  ip        String?
  createdAt DateTime @default(now())

  actor     User?    @relation("ActorLogs", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([action])
}

// NexTradePro (NXP) — Prisma schema
// Postgres (Neon). RBAC with granular admin roles is the core of this schema.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Authentication & Users
// ---------------------------------------------------------------------------

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum KycStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String
  fullName      String
  avatarUrl     String?
  status          UserStatus @default(ACTIVE)
  kycStatus       KycStatus  @default(NONE)
  twoFactor       Boolean    @default(false)
  twoFactorSecret String?
  referralCode    String?    @unique
  referredById    String?
  brokerId        String?
  demoMode      Boolean    @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  roles         UserRole[]
  wallets       Wallet[]
  orders        Order[]
  transactions  Transaction[]
  apiKeys       ApiKey[]
  kycSubmissions KycSubmission[]
  notifications Notification[]
  referrals     User[]          @relation("Referrals")
  referredBy    User?           @relation("Referrals", fields: [referredById], references: [id])
  clients       User[]          @relation("BrokerClients")
  broker        User?           @relation("BrokerClients", fields: [brokerId], references: [id])
  auditLogs     AuditLog[]      @relation("ActorLogs")
  assignedRoles UserRole[]      @relation("AssignedBy")

  @@index([email])
  @@index([status])
}

// ---------------------------------------------------------------------------
// RBAC: Roles + Permissions (many-to-many) + per-user role assignment
// Admin "types" (Withdrawal-Approval Admin, General Admin, KYC Admin, ...) are
// modelled as roles that bundle a set of permissions. A Super Admin assigns
// these roles to any registered user.
// ---------------------------------------------------------------------------

model Role {
  id          String           @id @default(cuid())
  key         String           @unique // e.g. SUPER_ADMIN, WITHDRAWAL_ADMIN
  name        String                   // "Withdrawal Approval Admin"
  description String?
  isSystem    Boolean          @default(false) // system roles cannot be deleted
  isAdmin     Boolean          @default(false) // grants access to the admin panel
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  users       UserRole[]
  permissions RolePermission[]

  @@index([key])
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique // e.g. withdrawals.approve, users.manage
  name        String
  group       String                   // "Withdrawals", "Users", "KYC", ...
  description String?
  createdAt   DateTime         @default(now())

  roles       RolePermission[]

  @@index([group])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model UserRole {
  id           String   @id @default(cuid())
  userId       String
  roleId       String
  assignedById String?
  assignedAt   DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedBy   User?    @relation("AssignedBy", fields: [assignedById], references: [id])

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

// ---------------------------------------------------------------------------
// Trading domain (demo / simulated execution on live prices)
// Every user has fully separate DEMO and LIVE data — wallets, orders and
// transactions are all scoped by `mode`.
// ---------------------------------------------------------------------------

enum AccountMode {
  DEMO
  LIVE
}

model Wallet {
  id        String      @id @default(cuid())
  userId    String
  asset     String      // BTC, ETH, USDT ...
  mode      AccountMode @default(DEMO)
  balance   Decimal     @default(0) @db.Decimal(24, 8)
  locked    Decimal     @default(0) @db.Decimal(24, 8)
  frozen    Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, asset, mode])
  @@index([userId, mode])
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
  STOP
}

enum OrderStatus {
  OPEN
  FILLED
  CANCELLED
  REJECTED
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  mode      AccountMode @default(DEMO)
  symbol    String      // BTCUSDT
  side      OrderSide
  type      OrderType
  leverage   Int        @default(1)
  price      Decimal    @db.Decimal(24, 8)
  amount     Decimal    @db.Decimal(24, 8)
  stopLoss   Decimal?   @db.Decimal(24, 8)
  takeProfit Decimal?   @db.Decimal(24, 8)
  filled     Decimal    @default(0) @db.Decimal(24, 8)
  status    OrderStatus @default(OPEN)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, mode])
  @@index([symbol])
}

enum TxType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
}

enum TxStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
}

model Transaction {
  id          String      @id @default(cuid())
  userId      String
  mode        AccountMode @default(DEMO)
  type        TxType
  asset       String
  network     String?
  address     String?
  amount      Decimal     @db.Decimal(24, 8)
  fee         Decimal     @default(0) @db.Decimal(24, 8)
  status      TxStatus    @default(PENDING)
  reference   String?
  note        String? // internal admin note
  reviewedById String?
  reviewedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, mode])
  @@index([status])
  @@index([type])
}

// Admin-managed deposit wallet addresses per asset/network (demo).
model WalletAddress {
  id           String   @id @default(cuid())
  asset        String
  network      String
  address      String
  minDeposit   String   @default("0")
  confirmations Int     @default(2)
  instructions String?
  isDefault    Boolean  @default(false)
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([asset, network])
  @@index([asset])
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  TRADE
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  body      String
  type      NotificationType @default(INFO)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String?
  enabled     Boolean  @default(false)
  updatedAt   DateTime @updatedAt
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model KycSubmission {
  id        String    @id @default(cuid())
  userId    String
  fullName  String
  country   String
  idType    String // PASSPORT, NATIONAL_ID, DRIVERS_LICENSE
  idNumber  String
  dob       String
  status    KycStatus @default(PENDING)
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  label     String
  prefix    String // shown to the user, e.g. nxp_live_AbC1
  lastFour  String
  revoked   Boolean   @default(false)
  createdAt DateTime  @default(now())
  lastUsed  DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Announcements / news — managed by Content Admins, shown on the public site
// ---------------------------------------------------------------------------

enum AnnouncementCategory {
  UPDATE
  MARKET
  SECURITY
  PROMOTION
}

model Announcement {
  id         String               @id @default(cuid())
  title      String
  body       String
  category   AnnouncementCategory  @default(UPDATE)
  published  Boolean               @default(true)
  authorId   String?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@index([published])
  @@index([category])
}

// ---------------------------------------------------------------------------
// Audit logging — every admin action is recorded
// ---------------------------------------------------------------------------

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String   // role.assign, withdrawal.approve, user.suspend ...
  target    String?  // affected entity id
  meta      Json?
  ip        String?
  createdAt DateTime @default(now())

  actor     User?    @relation("ActorLogs", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([action])
}

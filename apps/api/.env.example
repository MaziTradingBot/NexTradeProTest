# ── NexTradePro API environment ───────────────────────────────────────────
NODE_ENV=development
PORT=4000

# Postgres (Neon). Use a pooled connection string in production.
DATABASE_URL="postgresql://user:password@host:5432/nxp?sslmode=require"

# JWT secrets — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# Optional cookie domain for cross-subdomain auth (e.g. .nextradepro.com)
COOKIE_DOMAIN=
